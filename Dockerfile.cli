FROM golang:1.22-alpine AS builder
RUN apk add --no-cache git
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 go build \
    -ldflags="-s -w -X main.version=${VERSION}" \
    -o /cnpg-console ./cmd/cnpg-console

FROM alpine:3.20
RUN apk add --no-cache ca-certificates helm kubectl
COPY --from=builder /cnpg-console /usr/local/bin/cnpg-console
USER 65534:65534
ENTRYPOINT ["cnpg-console"]
